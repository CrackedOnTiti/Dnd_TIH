# Copy to .env and fill in your values

# Host account credentials (created on first launch)
HOST_USERNAME=host
HOST_PIN=0000

# DuckDNS token for automatic HTTPS cert
DUCKDNS_TOKEN=your-duckdns-token-here

# Database path (inside container, don't change unless you know what you're doing)
DATABASE_URL=sqlite:/app/data/dnd.db

# Log level: error, warn, info, debug
RUST_LOG=info
